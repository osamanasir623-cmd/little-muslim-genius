generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  language             String    @default("en")
  muted                Boolean   @default(false)
  paymentStatus        String    @default("trial")
  paymentMethod        String?
  paidAt               DateTime?
  subscriptionEndDate  DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  lastLogin            DateTime?
  isAdmin              Boolean   @default(false)
  blocked              Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profiles Profile[]
  payments Payment[]
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  avatar             String   @default("🐣")
  age                Int      @default(6)
  languagePreference String   @default("en")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  data ProfileData?
}

model ProfileData {
  id                String    @id @default(cuid())
  profileId         String    @unique
  currentDay        Int       @default(1)
  completedDays     Int[]     @default([])
  lastCompletedDate String?
  timerState        Json      @default("{}")
  stars             Int       @default(0)
  beads             Int       @default(0)
  badges            Int       @default(0)
  stickers          Int       @default(0)
  loginStreak       Int       @default(0)
  lastLoginDate     String?
  cartoonUnlocks    Int[]     @default([])
  cityBuildings     String[]  @default([])
  lastAccessedAt    DateTime?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String   @id @default(cuid())
  userId         String
  amountPkr      Float    @default(0)
  currency       String   @default("PKR")
  paymentGateway String
  transactionId  String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Day {
  id        String   @id @default(cuid())
  dayNumber Int      @unique
  world     String   @default("light")
  title     Json
  games     Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Puzzle {
  id        String   @id @default(cuid())
  topic     String
  title     Json
  pieces    Json
  learnFact String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
