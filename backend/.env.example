# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────────
# Get free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/little-muslim-genius?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# ── Email (SMTP) ────────────────────────────────────────────────────
# Works with SendGrid, Mailgun, Gmail, or any SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@littlemuslimgenius.com
EMAIL_FROM_NAME=Little Muslim Genius

# ── Stripe ──────────────────────────────────────────────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_PKR=1000

# ── JazzCash ────────────────────────────────────────────────────────
# Apply for merchant account at https://sandbox.jazzcash.com.pk
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_merchant_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_SANDBOX=true

# ── EasyPaisa ───────────────────────────────────────────────────────
# Apply at https://easypaisa.com.pk/easypay
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_SANDBOX=true

# ── Frontend ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
